<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <title>Admin Panel | Scatch</title>
</head>

<body class="bg-gray-100">

  <div class="flex min-h-screen">

    <!-- SIDEBAR -->
    <div class="w-64 bg-gray-900 text-white flex flex-col justify-between p-5">
      <div>
        <h1 class="text-2xl font-bold mb-6">Scatch Admin</h1>

        <nav class="flex flex-col gap-3">
          <a href="/products/removeproducts" class="hover:bg-gray-700 p-2 rounded-lg">All Products</a>
          <a href="/owners/adminPanel" class="bg-blue-600 p-2 rounded-lg">Create Product</a>
        </nav>
      </div>

      <a href="/owners/logout" class="bg-red-500 text-center py-2 rounded-lg hover:bg-red-600">
        Logout
      </a>
    </div>

    <!-- MAIN CONTENT -->
    <div class="flex-1 p-6">

      <h2 class="text-2xl font-semibold mb-6 text-gray-800">
        Create New Product
      </h2>

      <div class="bg-white p-6 rounded-2xl shadow-md max-w-3xl">

        <form action="/products/createproducts" method="post" enctype="multipart/form-data" class="grid md:grid-cols-2 gap-6">

          <!-- LEFT -->
          <div class="flex flex-col gap-4">
            <h3 class="font-semibold text-gray-700">Product Details</h3>

            <input type="file" name="image" required
              class="p-2 border rounded-lg bg-gray-50"/>

            <input type="text" name="name" placeholder="Product Name" required
              class="p-3 rounded-lg bg-gray-100 focus:ring-2 focus:ring-blue-400 outline-none"/>

            <input type="number" name="price" placeholder="Product Price" required
              class="p-3 rounded-lg bg-gray-100 focus:ring-2 focus:ring-blue-400 outline-none"/>

            <input type="number" name="discount" placeholder="Discount (₹)"
              class="p-3 rounded-lg bg-gray-100 focus:ring-2 focus:ring-blue-400 outline-none"/>
          </div>

          <!-- RIGHT -->
          <div class="flex flex-col gap-4">
            <h3 class="font-semibold text-gray-700">Panel Styling</h3>

            <input type="text" name="bgcolor" placeholder="Background Color (#ffffff)"
              class="p-3 rounded-lg bg-gray-100 focus:ring-2 focus:ring-blue-400 outline-none"/>

            <input type="text" name="panelcolor" placeholder="Panel Color (#000000)" required
              class="p-3 rounded-lg bg-gray-100 focus:ring-2 focus:ring-blue-400 outline-none"/>

            <input type="text" name="textcolor" placeholder="Text Color (#ffffff)" required
              class="p-3 rounded-lg bg-gray-100 focus:ring-2 focus:ring-blue-400 outline-none"/>
          </div>

          <!-- SUBMIT -->
          <div class="md:col-span-2">
            <button
              type="submit"
              class="w-full bg-blue-600 text-white py-3 rounded-xl font-semibold hover:bg-blue-700 transition"
            >
              Create Product
            </button>
          </div>

        </form>
      </div>

    </div>
  </div>

</body>
</html>