<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>Scatch | Auth</title>
  </head>

  <body class="bg-gradient-to-br from-blue-100 via-white to-purple-100 min-h-screen flex items-center justify-center">

    <!-- Main Container -->
    <div class="w-full max-w-6xl bg-white shadow-2xl rounded-3xl overflow-hidden grid lg:grid-cols-2">

      <!-- LEFT SIDE -->
      <div class="hidden lg:flex flex-col justify-center items-center bg-blue-600 text-white p-10">
        <h1 class="text-4xl font-bold mb-4">Scatch</h1>
        <p class="text-lg text-center opacity-90">
          Fast. Simple. Smart Shopping.
        </p>

        <div class="mt-10 text-center">
          <p class="mb-2">Are you an admin?</p>
          <a href="/owners/ownerLogin" class="underline hover:text-gray-200">
            Login as Admin
          </a>
        </div>
      </div>

      <!-- RIGHT SIDE -->
      <div class="p-8 lg:p-12 flex flex-col justify-center">

        <h2 class="text-3xl font-bold text-gray-800 mb-6">
          Welcome 👋
        </h2>

        <!-- SIGNUP -->
        <div class="mb-10">
          <h3 class="text-xl font-semibold mb-3 text-blue-600">Create Account</h3>

          <form action="/users/register" method="post" class="space-y-4">

            <input
              class="w-full p-3 rounded-xl bg-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-400"
              type="text"
              placeholder="Full Name"
              name="fullname"
              required
            />

            <input
              class="w-full p-3 rounded-xl bg-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-400"
              type="email"
              placeholder="Email"
              name="email"
              required
            />

            <!-- PASSWORD WITH TOGGLE -->
            <div class="relative">
              <input
                id="signupPassword"
                class="w-full p-3 pr-12 rounded-xl bg-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-400"
                type="password"
                placeholder="Password"
                name="password"
                required
              />

              <button
                type="button"
                onclick="togglePassword('signupPassword', this)"
                class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-600"
              >
                👁️
              </button>
            </div>

            <button
              type="submit"
              class="w-full bg-blue-600 text-white py-3 rounded-xl font-semibold hover:bg-blue-700 transition duration-200 active:scale-95"
            >
              Create Account
            </button>
          </form>
        </div>

        <!-- Divider -->
        <div class="flex items-center gap-3 my-6">
          <hr class="flex-1 border-gray-300" />
          <span class="text-gray-500 text-sm">OR</span>
          <hr class="flex-1 border-gray-300" />
        </div>

        <!-- LOGIN -->
        <div>
          <h3 class="text-xl font-semibold mb-3 text-green-600">Login</h3>

          <form action="/users/login" method="post" class="space-y-4">

            <input
              class="w-full p-3 rounded-xl bg-gray-100 focus:outline-none focus:ring-2 focus:ring-green-400"
              type="email"
              placeholder="Email"
              name="email"
              required
            />

            <!-- PASSWORD WITH TOGGLE -->
            <div class="relative">
              <input
                id="loginPassword"
                class="w-full p-3 pr-12 rounded-xl bg-gray-100 focus:outline-none focus:ring-2 focus:ring-green-400"
                type="password"
                placeholder="Password"
                name="password"
                required
              />

              <button
                type="button"
                onclick="togglePassword('loginPassword', this)"
                class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-600"
              >
                👁️
              </button>
            </div>

            <button
              type="submit"
              class="w-full bg-green-600 text-white py-3 rounded-xl font-semibold hover:bg-green-700 transition duration-200 active:scale-95"
            >
              Login
            </button>
          </form>
        </div>

        <!-- MOBILE ADMIN LINK -->
        <div class="mt-6 text-center lg:hidden">
          <a href="/owners/ownerLogin" class="text-blue-600 underline">
            Admin Login
          </a>
        </div>

      </div>
    </div>

    <!-- SCRIPT -->
    <script>
      function togglePassword(id, btn) {
        const input = document.getElementById(id);

        if (input.type === "password") {
          input.type = "text";
          btn.textContent = "🙈";
        } else {
          input.type = "password";
          btn.textContent = "👁️";
        }
      }
    </script>

  </body>
</html>