<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <title>My Account | Scatch</title>
</head>

<body class="bg-gray-100">

  <!-- HEADER -->
  <div class="bg-white shadow-md sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 py-3 flex justify-between items-center">
      <h2 class="text-2xl font-bold text-blue-600">Scatch</h2>
      <%- include('partials/header') %>
    </div>
  </div>

  <!-- MAIN -->
  <div class="max-w-5xl mx-auto px-4 py-8">

    <h1 class="text-3xl font-bold text-gray-800 mb-6">
      My Account 👤
    </h1>

    <!-- PROFILE CARD -->
    <div class="bg-white rounded-2xl shadow-md p-6 mb-6">
      <h2 class="text-xl font-semibold text-gray-700 mb-4">
        Profile Info
      </h2>

      <div class="space-y-2">
        <p class="text-gray-600">
          <span class="font-semibold text-gray-800">Name:</span>
          <%= user.fullname %>
        </p>

        <p class="text-gray-600">
          <span class="font-semibold text-gray-800">Email:</span>
          <%= user.email %>
        </p>
      </div>
    </div>

    <!-- STATS -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-6">

      <div class="bg-white p-5 rounded-xl shadow text-center">
        <p class="text-gray-500 text-sm">Cart Items</p>
        <h2 class="text-2xl font-bold text-blue-600">
          <%= user.cart.length %>
        </h2>
      </div>

      <div class="bg-white p-5 rounded-xl shadow text-center">
        <p class="text-gray-500 text-sm">Orders</p>
        <h2 class="text-2xl font-bold text-green-600">
          0
        </h2>
      </div>

      <div class="bg-white p-5 rounded-xl shadow text-center">
        <p class="text-gray-500 text-sm">Status</p>
        <h2 class="text-lg font-semibold text-gray-800">
          Active
        </h2>
      </div>

    </div>

    <!-- ACTIONS -->
    <div class="bg-white rounded-2xl shadow-md p-6">
      <h2 class="text-xl font-semibold text-gray-700 mb-4">
        Actions
      </h2>

      <div class="flex flex-col sm:flex-row gap-4">

        <a
          href="/users/cart"
          class="flex-1 text-center bg-blue-600 text-white py-3 rounded-xl font-semibold hover:bg-blue-700 transition"
        >
          View Cart 🛒
        </a>

        <a
          href="/users/orders"
          class="flex-1 text-center bg-green-600 text-white py-3 rounded-xl font-semibold hover:bg-green-700 transition"
        >
          My Orders 📦
        </a>

        <a
          href="/users/logout"
          class="flex-1 text-center bg-red-500 text-white py-3 rounded-xl font-semibold hover:bg-red-600 transition"
        >
          Logout 🚪
        </a>

      </div>
    </div>

  </div>

</body>
</html>