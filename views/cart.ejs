<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <title>My Cart | Scatch</title>
</head>

<body class="bg-gray-100">

  <!-- HEADER -->
  <div class="bg-white shadow-md sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 py-3 flex justify-between items-center">
      <h2 class="text-2xl font-bold text-blue-600">Scatch</h2>
      <%- include('partials/header') %>
    </div>
  </div>

  <!-- MAIN -->
  <div class="max-w-7xl mx-auto px-4 py-6 grid lg:grid-cols-3 gap-6">

    <!-- LEFT: CART ITEMS -->
    <div class="lg:col-span-2 flex flex-col gap-4">

      <h1 class="text-2xl font-semibold text-gray-700 mb-2">
        My Cart 🛒
      </h1>

      <% userCart.cart.reverse().map((product)=>{ %>

      <!-- ITEM CARD -->
      <div class="bg-white rounded-2xl shadow-md p-4 flex flex-col sm:flex-row gap-4 items-center justify-between">

        <!-- IMAGE -->
        <div class="h-24 w-24 rounded-lg overflow-hidden">
          <img
            class="h-full w-full object-cover"
            src="data:image/jpeg;base64,<%= product.image.toString('base64') %>"
            alt="image unavailable"
          />
        </div>

        <!-- DETAILS -->
        <div class="flex-1 w-full">
          <h2 class="font-semibold text-lg text-gray-800">
            <%= product.name %>
          </h2>

          <div class="flex gap-3 items-center mt-1">
            <p class="text-lg font-bold text-gray-900">
              ₹ <%= product.price %>
            </p>
            <p class="text-sm text-green-600">
              ₹ <%= product.discount %> off
            </p>
          </div>

          <p class="text-sm text-gray-600 mt-1">
            Total: ₹ <%= product.price - product.discount %>
          </p>
        </div>

        <!-- ACTIONS -->
        <div class="flex flex-col sm:flex-row gap-2">

          <a
            href="/users/orderPlaced"
            class="px-4 py-2 bg-green-600 text-white rounded-lg text-sm font-semibold hover:bg-green-700 transition"
          >
            Buy Now
          </a>

          <a
            href="/users/cart/<%=product._id %>"
            class="px-4 py-2 bg-red-500 text-white rounded-lg text-sm font-semibold hover:bg-red-600 transition"
          >
            Remove
          </a>

        </div>
      </div>

      <% }) %>

    </div>

    <!-- RIGHT: SUMMARY -->
    <div class="bg-white rounded-2xl shadow-md p-5 h-fit">

      <h2 class="text-xl font-semibold mb-4 text-gray-800">
        Price Details
      </h2>

      <div class="flex justify-between mb-2 text-gray-700">
        <span>Total Items</span>
        <span><%= userCart.cart.length %></span>
      </div>

      <div class="flex justify-between mb-2 text-gray-700">
        <span>Total Price</span>
        <span>
          ₹
          <%= userCart.cart.reduce((acc, item) => acc + item.price, 0) %>
        </span>
      </div>

      <div class="flex justify-between mb-4 text-green-600 font-semibold">
        <span>Total Discount</span>
        <span>
          - ₹
          <%= userCart.cart.reduce((acc, item) => acc + item.discount, 0) %>
        </span>
      </div>

      <hr class="mb-4">

      <div class="flex justify-between text-lg font-bold text-gray-900 mb-4">
        <span>Final Amount</span>
        <span>
          ₹
          <%= userCart.cart.reduce((acc, item) => acc + (item.price - item.discount), 0) %>
        </span>
      </div>

      <a
        href="/users/orderPlaced"
        class="w-full block text-center bg-blue-600 text-white py-3 rounded-xl font-semibold hover:bg-blue-700 transition"
      >
        Place Order
      </a>

    </div>

  </div>

</body>
</html>